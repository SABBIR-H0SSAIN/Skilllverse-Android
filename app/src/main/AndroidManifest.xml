        <activity
            android:name=".admin.AdminUsersActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.Admin"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".admin.ManageModulesActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.Admin"
            android:screenOrientation="portrait" />
            
        <activity
            android:name=".admin.ManageResourcesActivity"
            android:exported="false"
            android:label="Manage Resources"
            android:theme="@style/Theme.Skillverse_android.Admin"
            android:screenOrientation="portrait"
            android:parentActivityName=".admin.ManageModulesActivity" />
    </application>

</manifest>