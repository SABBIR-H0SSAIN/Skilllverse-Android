<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Skillverse_android">
        
        
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        
        
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.UserPanel"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".BrowseCoursesActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.UserPanel"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".CourseDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.UserPanel"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".MyCoursesActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.UserPanel"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.UserPanel"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".MyCertificatesActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.UserPanel"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".ModuleDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.UserPanel"
            android:screenOrientation="portrait" />
        
        
        <activity
            android:name=".admin.AdminDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.Admin"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".admin.AdminCoursesActivity"
            android:exported="false"
            android:theme="@style/Theme.Skillverse_android.Admin"
            android:screenOrientation="portrait" />
        
        <activity
            android:name=".admin.AdminInstructorsActivity"
            android:exported="false"
